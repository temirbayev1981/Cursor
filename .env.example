# Environment variables
# Copy to .env.local for local development: cp .env.example .env.local

# Supabase (required for production — omit for demo mode)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Optional overrides (defaults to Supabase Edge Functions when Supabase is set)
VITE_STRIPE_CHECKOUT_ENDPOINT=
VITE_STRIPE_SUBSCRIPTION_ENDPOINT=

# Google Maps (dispatch map & routing)
VITE_GOOGLE_MAPS_API_KEY=

# OpenAI (prefer Edge Function proxy; browser key not recommended)
VITE_OPENAI_PROXY_ENDPOINT=
VITE_OPENAI_API_KEY=

# Notifications (Resend via Edge Function or custom webhook)
VITE_NOTIFICATION_WEBHOOK_URL=
VITE_SMS_WEBHOOK_URL=

# Observability
VITE_SENTRY_DSN=
VITE_ERROR_WEBHOOK_URL=

# Build metadata (injected in CI deploy workflow)
# VITE_APP_VERSION=1.6.0

# E2E only — enables /e2e/crash route in Playwright builds (playwright.config.ts)
# VITE_ENABLE_E2E_ROUTES=true

# GitHub Pages base path (set in CI for project pages deploy)
# VITE_BASE_PATH=/Cursor/
